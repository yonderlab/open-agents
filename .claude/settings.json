{
  "permissions": {
    "allow": [
      "Bash(bun add:*)",
      "Bash(bun run typecheck:*)",
      "Bash(cd * && bun run typecheck:*)",
      "Bash(bun run format:*)",
      "Bash(cd * && bun run format:*)",
      "Bash(turbo:*)",
      "Bash(cd * && turbo:*)",
      "Bash(ls:*)",
      "Bash(bun -e:*)",
      "WebSearch",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(jq:*)",
      "Bash(python3 -c:*)",
      "Bash(git commit:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read file_path; if echo \"$file_path\" | grep -qE '\\.(ts|tsx|js|jsx|json)$'; then bunx biome format --write \"$file_path\"; fi; }"
          }
        ]
      }
    ]
  }
}
